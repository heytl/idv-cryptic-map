# 构建产物均为内容哈希文件名：一年 immutable，内容变化 = 文件名变化，永不用手动清缓存
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML 与 Service Worker 相关文件始终回源验证（体积小、无哈希），
# 保证部署后用户刷新即拿到新资源引用、SW 及时更新
/
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

/sw.js
  Cache-Control: no-cache, must-revalidate

/registerSW.js
  Cache-Control: no-cache, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate
